# ─── Vocab Hero — Environment Variables ───────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and safe to store secrets.
#
#   cp .env.example .env.local
#
# ──────────────────────────────────────────────────────────────────────────────

# ── Gemini API (required for OCR, TTS, image gen, chatbot) ───────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: expose a key to the browser for client-side TTS / image generation
# (if left blank those features fall back gracefully)
# API_KEY=your-gemini-api-key-here


# ── PostgreSQL — Vocab Hero history storage ───────────────────────────────────
#
# Option A — Neon (recommended, free tier, Vercel-native):
#   1. Go to https://neon.tech  → New Project → copy the connection string
#   2. Paste it below
#   3. Run:  npm run db:setup
#
# Option B — Supabase (free tier):
#   1. Go to https://supabase.com → New Project
#   2. Settings → Database → Connection string → "URI" tab
#   3. Paste it below (replace [YOUR-PASSWORD] with your DB password)
#   4. Run:  npm run db:setup
#
# Option C — Railway / any hosted Postgres:
#   Paste your postgres:// connection string below.
#
POSTGRES_URL=postgres://user:password@host:5432/dbname?sslmode=require


# ── Vercel deployment only ───────────────────────────────────────────────────
# When deploying to Vercel, add POSTGRES_URL (and GEMINI_API_KEY) in:
#   Vercel dashboard → Your project → Settings → Environment Variables
# Vercel Postgres databases inject these automatically if you connect them
# via the Storage tab in your project dashboard.
